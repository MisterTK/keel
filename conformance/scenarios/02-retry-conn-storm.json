{
  "name": "retry-conn-storm",
  "description": "Consecutive connection resets back off exponentially (200ms then 400ms) before the third attempt succeeds.",
  "policy": {
    "defaults": {
      "outbound": {
        "retry": { "attempts": 3, "schedule": "exp(200ms, x2, max 30s)", "on": ["conn", "timeout", "429", "5xx"] }
      }
    }
  },
  "steps": [
    {
      "call": {
        "target": "api.example.com",
        "request": { "op": "GET api.example.com/items", "idempotent": true },
        "effect": [
          { "status": "error", "class": "conn", "message": "connection reset by peer" },
          { "status": "error", "class": "conn", "message": "connection reset by peer" },
          { "status": "ok", "payload": "ok" }
        ],
        "expect": {
          "result": "ok",
          "attempts": 3,
          "waits_ms": [200, 400]
        }
      }
    }
  ]
}
