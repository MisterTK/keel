{
  "name": "keelrun",
  "version": "0.3.0",
  "description": "The SQLite of durable execution — production-grade resilience for Node with zero code changes.",
  "type": "module",
  "main": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs"
    },
    "./ai-sdk": {
      "types": "./ai-sdk.d.ts",
      "import": "./ai-sdk.mjs"
    },
    "./hook": {
      "import": "./hook.mjs",
      "require": "./hook.cjs"
    },
    "./register": { "import": "./register.mjs" },
    "./testing": {
      "import": "./testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "keelrun-node-run": "./bin/keel-node-run.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "files": [
    "index.mjs",
    "index.d.ts",
    "ai-sdk.mjs",
    "ai-sdk.d.ts",
    "hook.mjs",
    "hook.cjs",
    "register.mjs",
    "testing.mjs",
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": ["keel", "keelrun", "resilience", "retry", "circuit-breaker", "durable", "fetch"],
  "license": "Apache-2.0"
}
